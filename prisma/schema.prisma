datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  EDITOR
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  pageType        String   @default("CUSTOM") // e.g. HOME, ABOUT, CUSTOM
  heroTitle       String?
  heroDescription String?
  sections        Json     @default("[]") // content blocks (JSON array)
  featuredImage   String?
  status          String   @default("DRAFT") // DRAFT, PUBLISHED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Service {
  id               String   @id @default(cuid())
  serviceName      String
  slug             String   @unique
  shortDescription String
  longDescription  String   @db.Text
  featuredImage    String?
  galleryImages    Json     @default("[]") // Array of image URLs
  seoTitle         String?
  metaDescription  String?
  metaKeywords     String?
  canonicalUrl     String?
  ogImage          String?
  schemaMarkup     Json     @default("{}") // Structured Schema Org markup
  faqSection       Json     @default("[]") // Array of { question, answer }
  ctaSection       Json     @default("{}") // CTA configuration { title, description, linkText, linkUrl }
  status           String   @default("DRAFT") // DRAFT, PUBLISHED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Media {
  id        String   @id @default(cuid())
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int
  folder    String   @default("/")
  createdAt DateTime @default(now())
}

model Settings {
  id           String   @id @default("global")
  siteName     String   @default("Porcellana Nobilita")
  logoUrl      String?
  contactEmail String?
  contactPhone String?
  footerText   String?
  socialLinks  Json     @default("{}") // e.g. { facebook: "", instagram: "" }
  trackingCode String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
